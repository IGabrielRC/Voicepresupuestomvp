# Server
PORT=3001

# Supabase. Backend uses service_role, so it bypasses RLS.
# Get these from your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY

# Telegram bot token. Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Public URL where the web frontend runs. Used in Telegram reply links.
# In production, set this to your Vercel URL (e.g. https://presupuestoya.vercel.app)
# For local dev, keep as http://localhost:5173
WEB_BASE_URL=http://localhost:5173

# Optional but RECOMMENDED in production: secret to verify Telegram webhooks.
# Generate a random string (e.g. openssl rand -hex 32) and set it here.
# Then when setting the webhook, pass it as the secret_token param:
#   curl ".../setWebhook?url=...&secret_token=YOUR_SECRET"
# Without this, anyone who knows your webhook URL can hit it.
WEBHOOK_SECRET=

# Optional admin token for the analytics summary endpoint.
# If unset, GET /api/admin/analytics/summary returns 503 disabled.
# Generate a random string (e.g. openssl rand -hex 32) and set it in production.
ADMIN_TOKEN=
