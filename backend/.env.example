# Server
PORT=3001

# Supabase. Backend uses service_role, so it bypasses RLS.
# Get these from your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_KEY

# Telegram bot token. Get one from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# Public URL where the web frontend runs. Used in Telegram reply links.
# For local dev, this is your Vite URL.
WEB_BASE_URL=http://localhost:5173

# Optional: secret to verify Telegram webhooks.
# Set this AND pass it as secret_token to setWebhook (see README).
WEBHOOK_SECRET=
